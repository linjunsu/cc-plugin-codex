{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/linjunsu/cc-plugin-codex/schemas/supervision-contract.schema.json",
  "title": "Codex supervised Claude Code task contract",
  "type": "object",
  "required": ["mode", "todos"],
  "properties": {
    "mode": {
      "enum": ["diagnose", "implement", "publish", "autonomous"]
    },
    "activeTodoId": {
      "type": "string",
      "minLength": 1
    },
    "todos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": ["id", "task"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "task": { "type": "string", "minLength": 1 },
              "acceptance": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "allowedPaths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verification": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
